{% extends 'base.html.twig' %}
{% block title %}Nouveau Projet{% endblock %}

{% block content %}
<div class="card" style="max-width: 700px; margin: 0 auto;">
    <div class="card-header"><h3 class="card-title">Lancer un nouveau projet</h3></div>
    <div class="card-body">
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nom) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    {{ form_label(form.budgetTotal, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.budgetTotal, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.budgetTotal) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.statut, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.statut, {'attr': {'class': 'form-control form-select'}}) }}
                    {{ form_errors(form.statut) }}
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateDebut) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.dateFin, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateFin) }}
                </div>
            </div>

            <div class="mt-16">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-rocket"></i> Créer le projet
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
