{% extends 'base.html.twig' %}
{% block title %}Projets{% endblock %}
{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Projets</span>
{% endblock %}
{% block header_actions %}
  {% if is_granted('ROLE_BUREAU') %}
  <a href="{{ path('projet_new') }}" class="header-btn primary"><i class="fas fa-plus"></i> Nouveau projet</a>
  {% endif %}
{% endblock %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-title">Projets de l'association</div>
    <div class="page-subtitle">Gestion des investissements et projets collectifs</div>
  </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;">
  {% for projet in projets %}
  <div class="card" style="transition:all .2s;">
    <div style="height:6px;background:linear-gradient(90deg,{{ projet.statut == 'Terminé' ? '#10b981,#34d399' : projet.statut == 'Annulé' ? '#ef4444,#f87171' : '#1a56db,#3b82f6' }});border-radius:14px 14px 0 0;"></div>
    <div class="card-body">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
        <h3 style="font-size:16px;font-weight:700;color:#1e293b;flex:1;">{{ projet.nom }}</h3>
        <span class="badge {{ projet.statutBadgeClass }}" style="margin-left:8px;flex-shrink:0;">{{ projet.statut }}</span>
      </div>
      {% if projet.description %}
      <p style="font-size:13px;color:#64748b;margin-bottom:14px;line-height:1.5;">{{ projet.description|slice(0,100) }}{% if projet.description|length > 100 %}…{% endif %}</p>
      {% endif %}

      {# Progression budget #}
      <div style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;font-size:12px;color:#64748b;margin-bottom:6px;">
          <span>Collecté : <strong style="color:#1a56db;">{{ projet.montantCollecte|number_format(0,',',' ') }} F</strong></span>
          <span>Budget : <strong>{{ projet.budgetTotal|number_format(0,',',' ') }} F</strong></span>
        </div>
        <div class="progress">
          <div class="progress-bar {{ projet.pourcentageAvancement == 100 ? 'pb-green' : 'pb-blue' }}" style="width:{{ projet.pourcentageAvancement }}%;"></div>
        </div>
        <div style="text-align:right;font-size:11px;color:#94a3b8;margin-top:4px;">{{ projet.pourcentageAvancement }}% financé</div>
      </div>

      {% if projet.benefices > 0 %}
      <div style="background:#f0fdf4;border-radius:8px;padding:10px;font-size:13px;color:#16a34a;font-weight:600;margin-bottom:12px;">
        <i class="fas fa-chart-line"></i> Bénéfices : {{ projet.benefices|number_format(0,',',' ') }} F CFA
      </div>
      {% endif %}

      <div style="display:flex;justify-content:space-between;font-size:12px;color:#94a3b8;border-top:1px solid #f1f5f9;padding-top:12px;">
        <span>{% if projet.dateDebut %}<i class="fas fa-play"></i> {{ projet.dateDebut|date('d/m/Y') }}{% endif %}</span>
        <span>{% if projet.dateFin %}<i class="fas fa-stop"></i> {{ projet.dateFin|date('d/m/Y') }}{% endif %}</span>
        <a href="{{ path('projet_show', {id: projet.id}) }}" class="btn btn-ghost btn-sm" style="color:#1a56db;padding:2px 8px;font-size:12px;"><i class="fas fa-eye"></i> Détails</a>
      </div>
    </div>
  </div>
  {% else %}
  <div style="grid-column:1/-1;text-align:center;padding:60px;color:#94a3b8;">
    <i class="fas fa-folder-open" style="font-size:48px;display:block;margin-bottom:16px;opacity:.2;"></i>
    <div style="font-size:16px;font-weight:600;">Aucun projet enregistré</div>
    {% if is_granted('ROLE_BUREAU') %}
    <a href="{{ path('projet_new') }}" class="btn btn-primary" style="margin-top:16px;"><i class="fas fa-plus"></i> Créer le premier projet</a>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endblock %}
