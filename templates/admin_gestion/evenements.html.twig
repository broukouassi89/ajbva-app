{% extends 'base.html.twig' %}
{% block title %}Calendrier & PV{% endblock %}

{% block javascripts %}
<script>
    function showPVModal(titre, contenu) {
        const modal = document.getElementById('important-modal');
        const body = modal.querySelector('.modal-body');
        const icon = modal.querySelector('.modal-icon');
        const title = modal.querySelector('.modal-title');

        title.innerText = "PV : " + titre;
        body.innerHTML = '<div class="pv-content">' + contenu + '</div>'; // Rendu du HTML enrichi
        icon.innerHTML = '<i class="fas fa-file-signature"></i>';
        icon.className = 'modal-icon modal-icon-success';

        modal.classList.add('show');
    }
</script>
{% endblock %}
{% block breadcrumb %}
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Calendrier</span>
{% endblock %}
{% block header_actions %}
    {% if is_granted('ROLE_BUREAU') %}
    <a href="{{ path('admin_evenement_new') }}" class="header-btn primary"><i class="fas fa-plus"></i> Événement</a>
    {% endif %}
{% endblock %}
{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Calendrier & Réunions</h1>
        <p class="page-subtitle">Suivi des événements et comptes-rendus</p>
    </div>
</div>
<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Événement</th>
                    <th>Lieu</th>
                    <th>Type</th>
                    <th>PV / Compte-rendu</th>
                </tr>
            </thead>
            <tbody>
                {% for e in evenements %}
                <tr>
                    <td class="fw-600">{{ e.dateDebut|date('d/m/Y H:i') }}</td>
                    <td>
                        <div class="fw-700">{{ e.titre }}</div>
                        <small class="text-muted">{{ e.description }}</small>
                    </td>
                    <td>{{ e.lieu ?? '—' }}</td>
                    <td><span class="badge badge-info">{{ e.type }}</span></td>
                    <td style="white-space:nowrap;">
                        <div style="display:flex;gap:8px;">
                            <a href="{{ path('admin_evenement_photos', {id: e.id}) }}" class="btn btn-sm btn-ghost" title="Photos">
                                <i class="fas fa-camera"></i> ({{ e.photos|length }})
                            </a>
                            {% if e.procesVerbal %}
                                <button class="btn btn-sm btn-outline" onclick="showPVModal('{{ e.titre|escape('js') }}', '{{ e.procesVerbal.contenu|escape('js') }}')">
                                    <i class="fas fa-file-alt"></i> Voir PV
                                </button>
                            {% else %}
                                {% if is_granted('ROLE_BUREAU') %}
                                <a href="{{ path('admin_pv_new', {id: e.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-pen"></i> Rédiger PV
                                </a>
                                {% else %}
                                <span class="text-muted italic">Non disponible</span>
                                {% endif %}
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="5" class="text-center py-4">Aucun événement enregistré.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
