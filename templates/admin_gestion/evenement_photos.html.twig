{% extends 'base.html.twig' %}
{% block title %}Galerie Photos - {{ evenement.titre }}{% endblock %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-images" style="color:#1a56db;"></i> Galerie Photos</div>
    <div class="page-subtitle">{{ evenement.titre }} ({{ evenement.dateDebut|date('d/m/Y') }})</div>
  </div>
  <a href="{{ path('admin_evenement_index') }}" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Retour</a>
</div>

{% if is_granted('ROLE_BUREAU') %}
<div class="card mb-24">
  <div class="card-header"><span class="card-title"><i class="fas fa-upload"></i> Ajouter des photos</span></div>
  <div class="card-body">
    <form method="POST" enctype="multipart/form-data" class="form-inline" style="display:flex;gap:12px;align-items:end;">
      <div class="form-group" style="flex:1;margin:0;">
        <label class="form-label">Sélectionner des images (Max 2Mo/image)</label>
        <input type="file" name="photos[]" class="form-control" accept="image/*" multiple required>
      </div>
      <button type="submit" class="btn btn-primary"><i class="fas fa-cloud-upload-alt"></i> Envoyer</button>
    </form>
  </div>
</div>
{% endif %}

<div style="display:grid;grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));gap:16px;">
  {% for photo in evenement.photos %}
    <div class="card" style="padding:8px;">
      <a href="{{ asset('uploads/events/' ~ photo.filename) }}" target="_blank">
        <img src="{{ asset('uploads/events/' ~ photo.filename) }}" style="width:100%;height:150px;object-fit:cover;border-radius:8px;">
      </a>
      <div style="font-size:10px;color:#94a3b8;margin-top:6px;text-align:center;">
        Ajoutée le {{ photo.createdAt|date('d/m/Y') }}
      </div>
    </div>
  {% else %}
    <div style="grid-column: 1 / -1; text-align:center;padding:60px;background:white;border-radius:16px;border:1px dashed #e2e8f0;">
      <i class="fas fa-camera" style="font-size:40px;color:#cbd5e1;margin-bottom:16px;"></i>
      <div style="color:#64748b;font-weight:600;">Aucune photo pour cet événement.</div>
    </div>
  {% endfor %}
</div>
{% endblock %}
