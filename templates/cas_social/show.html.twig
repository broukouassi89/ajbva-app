{% extends 'base.html.twig' %}
{% block title %}Cas social — {{ cas.type }}{% endblock %}
{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <a href="{{ path('cas_social_index') }}" style="color:#64748b;">Affaires Sociales</a>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">{{ cas.type }} — {{ cas.membre.nomComplet }}</span>
{% endblock %}

{% block content %}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

  {# Infos du cas #}
  <div class="card">
    <div class="card-header">
      <span class="card-title">
        <span style="font-size:22px;">{{ cas.typeIcon }}</span> {{ cas.type }}
      </span>
      <span class="badge {{ cas.statutBadgeClass }}">{{ cas.statutAssistance }}</span>
    </div>
    <div class="card-body" style="padding:0;">
      <div style="display:flex;align-items:center;gap:14px;padding:18px 20px;border-bottom:1px solid #f1f5f9;background:#fafbfc;">
        <img src="{{ cas.membre.photoUrl }}" class="avatar avatar-md" onerror="this.src='/images/avatar-default.svg'">
        <div>
          <div style="font-weight:700;font-size:16px;color:#1e293b;">{{ cas.membre.nomComplet }}</div>
          <div style="font-size:12px;color:#94a3b8;font-family:monospace;">{{ cas.membre.identifiant }}</div>
          <div style="margin-top:4px;"><span class="badge {{ cas.membre.statutBadgeClass }}">{{ cas.membre.statut }}</span></div>
        </div>
      </div>
      <table style="width:100%;">
        {% set infos = [
          ['calendar-alt', "Date de l'événement", cas.dateEvenement|date('d/m/Y')],
          ['money-bill-wave', 'Montant assistance', cas.montantAssistanceFormate],
          ['user-shield', 'Déclaré par', cas.declaredBy ? cas.declaredBy.displayName : 'N/A'],
          ['check-circle', 'Validé par', cas.validatedBy ? cas.validatedBy.displayName : 'En attente'],
          ['calendar-check', 'Date paiement', cas.datePaiementAssistance ? cas.datePaiementAssistance|date('d/m/Y') : 'Non payé'],
          ['clock', 'Déclaré le', cas.createdAt|date('d/m/Y à H:i')],
        ] %}
        {% for row in infos %}
        <tr style="border-bottom:1px solid #f8fafc;">
          <td style="padding:11px 18px;color:#64748b;font-size:13px;font-weight:500;width:45%;">
            <i class="fas fa-{{ row[0] }}" style="width:18px;text-align:center;margin-right:6px;"></i>{{ row[1] }}
          </td>
          <td style="padding:11px 18px;font-size:13.5px;font-weight:600;color:#1e293b;">{{ row[2] }}</td>
        </tr>
        {% endfor %}
        {% if cas.description %}
        <tr>
          <td style="padding:11px 18px;color:#64748b;font-size:13px;font-weight:500;vertical-align:top;">
            <i class="fas fa-comment-alt" style="width:18px;text-align:center;margin-right:6px;"></i>Description
          </td>
          <td style="padding:11px 18px;font-size:13px;color:#475569;line-height:1.5;">{{ cas.description }}</td>
        </tr>
        {% endif %}
      </table>
    </div>

    {# Actions workflow #}
    {% if is_granted('ROLE_BUREAU') %}
    <div style="padding:16px 18px;border-top:1px solid #e2e8f0;background:#fafbfc;">
      <div style="font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;">Gestion de l'assistance</div>
      <form method="POST" action="{{ path('cas_social_assistance', {id: cas.id}) }}" style="display:flex;gap:8px;flex-wrap:wrap;">
        {% if cas.statutAssistance == 'En attente' %}
        <button name="action" value="valider" class="btn btn-primary btn-sm"><i class="fas fa-check"></i> Valider</button>
        <button name="action" value="refuser" class="btn btn-danger btn-sm" onclick="return confirm('Refuser cette assistance ?')"><i class="fas fa-times"></i> Refuser</button>
        {% elseif cas.statutAssistance == 'Validée' %}
        <button name="action" value="payer" class="btn btn-success btn-sm"><i class="fas fa-coins"></i> Marquer comme payée</button>
        {% endif %}
      </form>
    </div>
    {% endif %}
  </div>

  {# Cotisations sociales collectées #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-coins" style="color:#f59e0b;"></i> Cotisations sociales générées</span>
    </div>
    <div class="card-body" style="padding-bottom:0;">
      {# Stat de collecte #}
      {% set nbTotal = cas.cotisationsSociales|length %}
      {% set nbPaye = cas.nbCotisationsSocialesPayees %}
      {% set pct = nbTotal > 0 ? ((nbPaye / nbTotal) * 100)|round : 0 %}
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px;">
        <span style="color:#64748b;font-weight:600;">{{ nbPaye }} / {{ nbTotal }} payées</span>
        <span style="font-weight:700;color:{{ pct == 100 ? '#10b981' : '#f59e0b' }};">{{ pct }}%</span>
      </div>
      <div class="progress" style="height:10px;margin-bottom:16px;">
        <div class="progress-bar {{ pct == 100 ? 'pb-green' : 'pb-yellow' }}" style="width:{{ pct }}%;"></div>
      </div>
      {% set totalAttendu = 0 %}
      {% for c in cas.cotisationsSociales %}{% set totalAttendu = totalAttendu + c.montant %}{% endfor %}
      <div style="font-size:13px;color:#64748b;margin-bottom:16px;">
        Total collecté : <strong style="color:#10b981;">{{ cas.totalCotisationsSocialesCollectees|number_format(0,',',' ') }} F CFA</strong>
        / Attendu : <strong>{{ totalAttendu|number_format(0,',',' ') }} F CFA</strong>
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Membre</th><th>Montant</th><th>Statut</th></tr></thead>
        <tbody>
          {% for c in cas.cotisationsSociales %}
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:8px;">
                <img src="{{ c.membre.photoUrl }}" class="avatar" style="width:28px;height:28px;" onerror="this.src='/images/avatar-default.svg'">
                <span style="font-size:13px;color:#1e293b;">{{ c.membre.nomComplet }}</span>
              </div>
            </td>
            <td style="font-weight:600;color:#10b981;">{{ c.montant|number_format(0,',',' ') }} F</td>
            <td><span class="badge {{ c.statutBadgeClass }}">{{ c.statutLabel }}</span></td>
          </tr>
          {% else %}
          <tr><td colspan="3" style="text-align:center;padding:20px;color:#94a3b8;">Aucune cotisation générée</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
