{% extends 'base.html.twig' %}
{% block title %}Affaires Sociales{% endblock %}
{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Affaires Sociales</span>
{% endblock %}
{% block header_actions %}
  {% if is_granted('ROLE_VP_SOCIAL') %}
  <a href="{{ path('cas_social_new') }}" class="header-btn primary"><i class="fas fa-plus"></i> Déclarer un cas</a>
  {% endif %}
{% endblock %}

{% block content %}

{# Filtres #}
<div class="card mb-24">
  <div class="card-body" style="padding:16px 20px;">
    <form method="GET" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
      <div>
        <label class="form-label" style="margin-bottom:4px;">Type</label>
        <select name="type" class="form-control form-select" style="min-width:180px;">
          <option value="">Tous les types</option>
          {% for t in types %}
          <option value="{{ t }}" {{ filters.type == t ? 'selected' : '' }}>{{ t }}</option>
          {% endfor %}
        </select>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Statut</label>
        <select name="statut" class="form-control form-select" style="min-width:140px;">
          <option value="">Tous</option>
          {% for s in statuts %}
          <option value="{{ s }}" {{ filters.statut == s ? 'selected' : '' }}>{{ s }}</option>
          {% endfor %}
        </select>
      </div>
      <div style="display:flex;gap:6px;">
        <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filtrer</button>
        <a href="{{ path('cas_social_index') }}" class="btn btn-outline"><i class="fas fa-times"></i></a>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-heart-pulse"></i> Cas sociaux déclarés</span>
    <span style="font-size:13px;color:#64748b;">{{ casSociaux.getTotalItemCount }} cas</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Type</th>
          <th>Membre</th>
          <th class="hide-mobile">Date</th>
          <th>Assistance</th>
          <th class="hide-tablet">Cotisations sociales</th>
          <th>Statut</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for cas in casSociaux %}
        <tr>
          <td>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:22px;">{{ cas.typeIcon }}</span>
              <span class="hide-mobile" style="font-weight:600;font-size:13px;">{{ cas.type }}</span>
            </div>
          </td>
          <td>
            <a href="{{ path('membre_show', {id: cas.membre.id}) }}" style="display:flex;align-items:center;gap:9px;text-decoration:none;">
              <img src="{{ cas.membre.photoUrl }}" class="avatar avatar-sm" onerror="this.src='/images/avatar-default.svg'">
              <div>
                <div style="font-weight:600;font-size:13px;color:#1e293b;">{{ cas.membre.nomComplet }}</div>
                <div class="hide-mobile" style="font-size:10.5px;color:#94a3b8;font-family:monospace;">{{ cas.membre.identifiant }}</div>
              </div>
            </a>
          </td>
          <td class="hide-mobile" style="color:#64748b;">{{ cas.dateEvenement|date('d/m/Y') }}</td>
          <td>
            <span style="font-weight:800;color:#1a56db;font-size:15px;">
              {{ cas.montantAssistanceFormate }}
            </span>
          </td>
          <td class="hide-tablet">
            <div style="font-size:12px;">
              <span style="font-weight:700;color:#10b981;">{{ cas.nbCotisationsSocialesPayees }}</span>
              <span style="color:#94a3b8;"> / {{ cas.cotisationsSociales|length }} payées</span>
            </div>
            {% if cas.cotisationsSociales|length > 0 %}
            <div style="margin-top:4px;">
              <div class="progress" style="height:5px;width:120px;">
                {% set pct = cas.cotisationsSociales|length > 0 ? ((cas.nbCotisationsSocialesPayees / cas.cotisationsSociales|length) * 100)|round : 0 %}
                <div class="progress-bar pb-green" style="width:{{ pct }}%;"></div>
              </div>
            </div>
            {% endif %}
          </td>
          <td><span class="badge {{ cas.statutBadgeClass }}">{{ cas.statutAssistance }}</span></td>
          <td style="text-align:right;">
            <div style="display:flex;gap:4px;justify-content:flex-end;">
              <a href="{{ path('cas_social_show', {id: cas.id}) }}" class="btn btn-ghost btn-sm" title="Détails">
                <i class="fas fa-eye"></i>
              </a>
              {% if is_granted('ROLE_BUREAU') and cas.statutAssistance == 'En attente' %}
              <form method="POST" action="{{ path('cas_social_assistance', {id: cas.id}) }}" style="display:inline;">
                <button name="action" value="valider" class="btn btn-ghost btn-sm" style="color:#10b981;" title="Valider">
                  <i class="fas fa-check"></i>
                </button>
              </form>
              {% endif %}
            </div>
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="7" style="text-align:center;padding:50px;color:#94a3b8;">
            <i class="fas fa-heart" style="font-size:36px;display:block;margin-bottom:12px;opacity:.2;"></i>
            Aucun cas social enregistré
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if casSociaux.pageCount > 1 %}
  <div class="pagination">{{ knp_pagination_render(casSociaux) }}</div>
  {% endif %}
</div>
{% endblock %}
