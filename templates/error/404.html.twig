{% extends 'base.html.twig' %}
{% block title %}Page introuvable — 404{% endblock %}

{% block content %}
<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:40px;">
  <div style="font-size:80px;font-weight:900;color:#e2e8f0;line-height:1;margin-bottom:16px;">404</div>
  <h1 style="font-size:24px;font-weight:700;color:#1e293b;margin-bottom:8px;">Page introuvable</h1>
  <p style="color:#64748b;font-size:15px;margin-bottom:28px;max-width:400px;">
    {{ message ?? "La page que vous cherchez n'existe pas ou a été déplacée." }}
  </p>
  <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
    <a href="{{ path('dashboard') }}" class="btn btn-primary btn-lg">
      <i class="fas fa-home"></i> Retour au tableau de bord
    </a>
    <button onclick="history.back()" class="btn btn-outline btn-lg">
      <i class="fas fa-arrow-left"></i> Page précédente
    </button>
  </div>
</div>
{% endblock %}
