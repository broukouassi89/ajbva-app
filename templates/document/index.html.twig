{% extends 'base.html.twig' %}
{% block title %}Espace Documentaire{% endblock %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-folder-open" style="color:#1a56db;"></i> Espace Documentaire</div>
    <div class="page-subtitle">Statuts, règlements et modèles officiels de l'AJBVA</div>
  </div>
  {% if is_granted('ROLE_BUREAU') %}
  <a href="{{ path('document_new') }}" class="btn btn-primary"><i class="fas fa-upload"></i> Ajouter un document</a>
  {% endif %}
</div>

<div class="stats-grid">
  {% for cat in categories %}
    <div class="stat-card">
      <div class="stat-icon si-blue"><i class="fas fa-file-alt"></i></div>
      <div style="flex:1;">
        <div class="stat-label">{{ cat }}</div>
        <div class="stat-value">{{ documents|filter(d => d.categorie == cat)|length }}</div>
      </div>
    </div>
  {% endfor %}
</div>

<div class="card">
  <div class="card-header"><span class="card-title"><i class="fas fa-list"></i> Liste des documents</span></div>
  <div class="card-body" style="padding:0;">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Document</th>
            <th class="hide-mobile">Catégorie</th>
            <th class="hide-tablet">Description</th>
            <th class="hide-mobile">Date</th>
            <th style="text-align:right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for doc in documents %}
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px;">
                  <i class="fas fa-file-pdf" style="color:#ef4444;font-size:20px;"></i>
                  <div>
                    <div style="font-weight:700;color:#1e293b;">{{ doc.titre }}</div>
                    <div class="hide-mobile" style="font-size:11px;color:#94a3b8;font-family:monospace;">{{ doc.filename }}</div>
                  </div>
                </div>
              </td>
              <td class="hide-mobile"><span class="badge" style="background:#f1f5f9;color:#64748b;">{{ doc.categorie }}</span></td>
              <td class="hide-tablet" style="font-size:13px;color:#64748b;max-width:300px;">{{ doc.description|default('—') }}</td>
              <td class="hide-mobile" style="font-size:13px;color:#64748b;">{{ doc.createdAt|date('d/m/Y') }}</td>
              <td style="text-align:right;">
                <div style="display:flex;gap:8px;justify-content:flex-end;">
                  {# Bouton Visualisation PDF #}
                  {% if doc.filename ends with '.pdf' %}
                  <button class="btn btn-primary btn-sm" 
                          onclick="showPDFViewer('{{ doc.titre|escape('js') }}', '{{ asset('uploads/documents/' ~ doc.filename) }}')"
                          title="Visualiser">
                    <i class="fas fa-book-open"></i>
                  </button>
                  {% endif %}
                  
                  <a href="{{ asset('uploads/documents/' ~ doc.filename) }}" target="_blank" class="btn btn-outline btn-sm" title="Télécharger">
                    <i class="fas fa-download"></i>
                  </a>
                  {% if is_granted('ROLE_BUREAU') %}
                  <form action="{{ path('document_delete', {id: doc.id}) }}" method="POST" onsubmit="return confirm('Supprimer ce document ?');" style="display:inline;">
                    <button type="submit" class="btn btn-ghost btn-sm" style="color:#ef4444;" title="Supprimer">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% else %}
            <tr><td colspan="5" style="text-align:center;padding:40px;color:#94a3b8;">Aucun document disponible.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
