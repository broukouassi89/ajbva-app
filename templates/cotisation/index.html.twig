{% extends 'base.html.twig' %}
{% block title %}Cotisations{% endblock %}
{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Cotisations</span>
{% endblock %}
{% block header_actions %}
  <a href="{{ path('cotisation_rapport') }}" class="header-btn"><i class="fas fa-chart-bar"></i> Rapport annuel</a>
  {% if is_granted('ROLE_BUREAU') %}
  <a href="{{ path('cotisation_new') }}" class="header-btn primary"><i class="fas fa-plus"></i> Nouveau paiement</a>
  {% endif %}
{% endblock %}

{% block content %}

{# Filtres #}
<div class="card mb-24">
  <div class="card-body" style="padding:16px 20px;">
    <form method="GET" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
      <div>
        <label class="form-label" style="margin-bottom:4px;">Type</label>
        <select name="type" class="form-control form-select" style="min-width:160px;">
          <option value="">Tous les types</option>
          <option value="mensuelle" {{ filters.type == 'mensuelle' ? 'selected' : '' }}>Mensuelle</option>
          <option value="exceptionnelle" {{ filters.type == 'exceptionnelle' ? 'selected' : '' }}>Exceptionnelle</option>
          <option value="sociale" {{ filters.type == 'sociale' ? 'selected' : '' }}>Sociale</option>
          <option value="adhesion" {{ filters.type == 'adhesion' ? 'selected' : '' }}>Adhésion</option>
        </select>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Statut</label>
        <select name="statut" class="form-control form-select" style="min-width:130px;">
          <option value="">Tous</option>
          <option value="payee" {{ filters.statut == 'payee' ? 'selected' : '' }}>Payée</option>
          <option value="partielle" {{ filters.statut == 'partielle' ? 'selected' : '' }}>Partielle</option>
          <option value="en_attente" {{ filters.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
        </select>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Année</label>
        <input type="number" name="annee" value="{{ filters.annee }}" class="form-control" style="width:90px;" min="2020" max="2099">
      </div>
      <div style="display:flex;gap:6px;">
        <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filtrer</button>
        <a href="{{ path('cotisation_index') }}" class="btn btn-outline"><i class="fas fa-times"></i></a>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-list"></i> Transactions</span>
    <div style="display:flex;align-items:center;gap:16px;">
      <span style="font-size:13px;color:#64748b;">{{ cotisations.getTotalItemCount }} résultat(s)</span>
      {% if totalFiltree > 0 %}
      <span style="font-size:14px;font-weight:700;color:#10b981;">Total : {{ totalFiltree|number_format(0,',',' ') }} F CFA</span>
      {% endif %}
    </div>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>N° Reçu</th>
          <th>Membre</th>
          <th>Type</th>
          <th>Montant</th>
          <th>Date paiement</th>
          <th>Mois concerné</th>
          <th>Statut</th>
          <th>Note</th>
        </tr>
      </thead>
      <tbody>
        {% for c in cotisations %}
        <tr>
          <td>
            <span class="font-mono" style="font-size:11.5px;color:#64748b;background:#f8fafc;padding:3px 8px;border-radius:6px;border:1px solid #e2e8f0;">
              {{ c.recuNumero ?? '—' }}
            </span>
          </td>
          <td>
            <a href="{{ path('membre_show', {id: c.membre.id}) }}" style="display:flex;align-items:center;gap:9px;text-decoration:none;">
              <img src="{{ c.membre.photoUrl }}" class="avatar avatar-sm" onerror="this.src='/images/avatar-default.svg'">
              <div>
                <div style="font-weight:600;font-size:13px;color:#1e293b;">{{ c.membre.nomComplet }}</div>
                <div style="font-size:10.5px;color:#94a3b8;font-family:monospace;">{{ c.membre.identifiant }}</div>
              </div>
            </a>
          </td>
          <td><span class="badge {{ c.typeBadgeClass }}">{{ c.typeLabel }}</span></td>
          <td>
            <span style="font-weight:800;color:#10b981;font-size:15px;">
              +{{ c.montant|number_format(0,',',' ') }} <span style="font-size:11px;font-weight:600;">F</span>
            </span>
          </td>
          <td style="color:#64748b;font-size:13px;">{{ c.datePaiement|date('d/m/Y') }}</td>
          <td>
            {% if c.moisConcerne %}
              <span style="background:#eff6ff;color:#1e40af;padding:3px 8px;border-radius:6px;font-size:12px;font-weight:600;">
                {{ c.moisConcerne }}
              </span>
            {% else %}—{% endif %}
          </td>
          <td><span class="badge {{ c.statutBadgeClass }}">{{ c.statutLabel }}</span></td>
          <td style="font-size:12px;color:#94a3b8;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
            {{ c.note ?? '—' }}
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="8" style="text-align:center;padding:50px;color:#94a3b8;">
            <i class="fas fa-coins" style="font-size:36px;display:block;margin-bottom:12px;opacity:.2;"></i>
            Aucune transaction trouvée
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if cotisations.pageCount > 1 %}
  <div class="pagination">{{ knp_pagination_render(cotisations) }}</div>
  {% endif %}
</div>
{% endblock %}
