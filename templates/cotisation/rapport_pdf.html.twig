<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport Annuel des Cotisations</title>
    <style>
        body { font-family: 'Helvetica', sans-serif; font-size: 12px; color: #333; }
        .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #1a56db; padding-bottom: 10px; }
        .title { font-size: 20px; font-weight: bold; color: #1a56db; }
        .subtitle { font-size: 14px; color: #666; margin-top: 5px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background-color: #f8fafc; color: #1e293b; font-weight: bold; padding: 10px; border: 1px solid #e2e8f0; text-align: left; }
        td { padding: 8px; border: 1px solid #e2e8f0; }
        .text-right { text-align: right; }
        .badge { padding: 3px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; }
        .badge-success { background-color: #dcfce7; color: #166534; }
        .badge-warning { background-color: #fef9c3; color: #854d0e; }
        .badge-danger { background-color: #fee2e2; color: #991b1b; }
        .footer { position: fixed; bottom: 0; width: 100%; text-align: center; font-size: 10px; color: #94a3b8; border-top: 1px solid #e2e8f0; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <div class="title">AJBVA - BOTRO</div>
        <div class="subtitle">Association des Jeunes de Botro et Villages Avoisinants</div>
        <div style="margin-top: 15px; font-size: 16px; font-weight: bold;">RAPPORT ANNUEL DES COTISATIONS - ANNÉE {{ annee }}</div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Membre</th>
                <th>Identifiant</th>
                <th class="text-right">Total Payé</th>
                <th class="text-right">Reste à Payer</th>
                <th>Progression</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for r in rapport %}
                <tr>
                    <td><strong>{{ r.membre.nomComplet }}</strong></td>
                    <td style="font-family: monospace;">{{ r.membre.identifiant }}</td>
                    <td class="text-right">{{ r.totalPaye|number_format(0,',',' ') }} F</td>
                    <td class="text-right">{{ r.resteAPayer|number_format(0,',',' ') }} F</td>
                    <td>{{ r.pourcentage }}%</td>
                    <td>
                        <span class="badge {{ r.statut == 'Complet' ? 'badge-success' : (r.statut == 'Partiel' ? 'badge-warning' : 'badge-danger') }}">
                            {{ r.statut }}
                        </span>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Document généré le {{ "now"|date("d/m/Y à H:i") }} - AJBVA Gestion
    </div>
</body>
</html>
