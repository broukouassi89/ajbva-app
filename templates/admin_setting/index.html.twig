{% extends 'base.html.twig' %}

{% block title %}Paramètres de l'Association{% endblock %}

{% block breadcrumb %}
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Paramètres</span>
{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Configuration des Paramètres</h1>
        <p class="page-subtitle">Gérez les montants des cotisations et des assistances sociales</p>
    </div>
</div>

<div class="card" style="max-width: 800px;">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-cogs"></i> Paramètres Financiers</h3>
    </div>
    <div class="card-body">
        <form method="POST">
            <div style="display: grid; gap: 20px;">
                {% for s in settings %}
                <div class="form-group">
                    <label class="form-label">{{ s.label }}</label>
                    <div class="input-group d-flex align-center gap-8">
                        <input type="{% if s.type == 'integer' or s.type == 'decimal' %}number{% else %}text{% endif %}" 
                               name="settings[{{ s.cle }}]" 
                               value="{{ s.valeur }}" 
                               class="form-control" 
                               {% if s.type == 'decimal' %}step="0.01"{% endif %}
                               required>
                        <span class="text-muted fw-600">F CFA</span>
                    </div>
                    <small class="form-hint">Clé système : <code>{{ s.cle }}</code></small>
                </div>
                {% endfor %}
            </div>

            <div class="mt-24 pt-16" style="border-top: 1px solid #eee;">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-24" style="max-width: 800px; border-left: 4px solid var(--info);">
    <div class="card-body">
        <div class="d-flex gap-12">
            <i class="fas fa-info-circle text-info" style="font-size: 20px;"></i>
            <div>
                <h4 class="fw-700 mb-4">Note importante</h4>
                <p class="text-muted" style="font-size: 13px;">
                    Les modifications apportées ici s'appliqueront aux <strong>futurs calculs</strong>. 
                    Les cotisations déjà générées ou les assistances déjà payées ne seront pas impactées rétroactivement.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
