{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current"><i class="fas fa-th-large"></i> Tableau de bord</span>
{% endblock %}

{% block header_actions %}
  <a href="{{ path('membre_new') }}" class="header-btn primary">
    <i class="fas fa-user-plus"></i> Nouveau membre
  </a>
{% endblock %}

{% block content %}

{# ─── KPIs ─── #}
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon si-blue"><i class="fas fa-users"></i></div>
    <div class="flex-1">
      <div class="stat-value">{{ stats.membres.total }}</div>
      <div class="stat-label">Total membres</div>
      <div class="stat-delta delta-up"><i class="fas fa-check-circle"></i> {{ stats.membres.Actif }} actifs</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-green"><i class="fas fa-user-check"></i></div>
    <div class="flex-1">
      <div class="stat-value">{{ stats.membres.Actif }}</div>
      <div class="stat-label">Membres actifs</div>
      <div class="stat-delta delta-down"><i class="fas fa-times-circle"></i> {{ stats.membres.Inactif }} inactifs</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-yellow"><i class="fas fa-coins"></i></div>
    <div class="flex-1">
      <div class="stat-value">{{ stats.cotisationsMoisCourant|number_format(0, ',', ' ') }}</div>
      <div class="stat-label">Cotisations ce mois (F CFA)</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-teal"><i class="fas fa-safe"></i></div>
    <div class="flex-1">
      <div class="stat-value" style="font-size:18px;">{{ stats.soldeCaisse|number_format(0, ',', ' ') }}</div>
      <div class="stat-label">Solde caisse (F CFA)</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-red"><i class="fas fa-heart-pulse"></i></div>
    <div class="flex-1">
      <div class="stat-value">{{ stats.casSociauxEnAttente }}</div>
      <div class="stat-label">Cas sociaux en attente</div>
      {% if stats.casSociauxEnAttente > 0 %}
        <a href="{{ path('cas_social_index') }}?statut=En+attente" class="stat-delta" style="color:#ef4444; text-decoration:none;">
          <i class="fas fa-arrow-right"></i> Voir les cas
        </a>
      {% endif %}
    </div>
  </div>
</div>

{# ─── GRAPHIQUES ROW 1 ─── #}
<div style="display:grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px;">

  {# Évolution cotisations mensuelles #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-chart-line" style="color:#1a56db"></i> Évolution des cotisations {{ stats.annee }}</span>
      <div style="display:flex; gap:8px; align-items:center;">
        <select id="anneeSelect" class="form-control form-select" style="width:100px; padding:6px 28px 6px 10px; font-size:12px;" onchange="chargerEvolution(this.value)">
          {% for y in range(stats.annee - 3, stats.annee) %}
          <option value="{{ y }}" {{ y == stats.annee ? 'selected' : '' }}>{{ y }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
    <div class="card-body">
      <div class="chart-container" style="height:250px;">
        <canvas id="chartEvolution"></canvas>
      </div>
    </div>
  </div>

  {# Répartition membres par statut (Doughnut) #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-chart-pie" style="color:#7c3aed"></i> Statuts membres</span>
    </div>
    <div class="card-body" style="text-align:center;">
      <div class="chart-container" style="height:200px;">
        <canvas id="chartStatuts"></canvas>
      </div>
      <div style="display:flex; justify-content:center; gap:16px; margin-top:12px; font-size:12px;">
        <div style="display:flex; align-items:center; gap:5px;"><span style="width:12px;height:12px;border-radius:50%;background:#10b981;display:inline-block;"></span>Actifs ({{ stats.membres.Actif }})</div>
        <div style="display:flex; align-items:center; gap:5px;"><span style="width:12px;height:12px;border-radius:50%;background:#ef4444;display:inline-block;"></span>Inactifs ({{ stats.membres.Inactif }})</div>
        <div style="display:flex; align-items:center; gap:5px;"><span style="width:12px;height:12px;border-radius:50%;background:#94a3b8;display:inline-block;"></span>Anciens ({{ stats.membres['Ancien Membre'] ?? 0 }})</div>
      </div>
    </div>
  </div>
</div>

{# ─── GRAPHIQUES ROW 2 ─── #}
<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 20px;">

  {# Répartition par village (Bar horizontal) #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-map-marker-alt" style="color:#f59e0b"></i> Par village</span>
    </div>
    <div class="card-body">
      <div class="chart-container" style="height:200px;">
        <canvas id="chartVillages"></canvas>
      </div>
    </div>
  </div>

  {# Répartition par genre (Doughnut) #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-venus-mars" style="color:#ec4899"></i> Genre</span>
    </div>
    <div class="card-body" style="text-align:center;">
      <div class="chart-container" style="height:200px;">
        <canvas id="chartGenre"></canvas>
      </div>
    </div>
  </div>

  {# Cotisations par type (Pie) #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-layer-group" style="color:#0ea5e9"></i> Types cotisations</span>
    </div>
    <div class="card-body">
      <div class="chart-container" style="height:200px;">
        <canvas id="chartTypes"></canvas>
      </div>
    </div>
  </div>
</div>

{# ─── DERNIERS MEMBRES & TRANSACTIONS ─── #}
<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px;">

  {# Derniers membres #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-user-plus" style="color:#10b981"></i> Nouveaux membres</span>
      <a href="{{ path('membre_new') }}" class="btn btn-sm btn-primary">+ Ajouter</a>
    </div>
    <div>
      {% for membre in derniersMembres %}
      <a href="{{ path('membre_show', {id: membre.id}) }}" style="display:flex; align-items:center; gap:12px; padding:12px 20px; border-bottom:1px solid #f1f5f9; transition:background .1s; text-decoration:none; color:inherit;" onmouseover="this.style.background='#fafbff'" onmouseout="this.style.background=''">
        <img src="{{ membre.photoUrl }}" alt="" class="avatar avatar-sm" onerror="this.src='/images/avatar-default.svg'">
        <div style="flex:1; min-width:0;">
          <div style="font-weight:700; font-size:13.5px; color:#1e293b;">{{ membre.nomComplet }}</div>
          <div class="hide-mobile" style="font-size:11px; color:#94a3b8; font-family:monospace;">{{ membre.identifiant }}</div>
        </div>
        <div style="text-align:right;">
          <span class="badge {{ membre.statutBadgeClass }}">{{ membre.statut }}</span>
          <div class="hide-mobile" style="font-size:11px; color:#94a3b8; margin-top:2px;">{{ membre.dateAdhesion|date('d/m/Y') }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
    <div style="padding:14px 20px; border-top:1px solid #f1f5f9;">
      <a href="{{ path('membre_index') }}" class="btn btn-outline" style="width:100%; justify-content:center;">Voir tous les membres</a>
    </div>
  </div>

  {# Dernières transactions #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-history" style="color:#1a56db"></i> Dernières transactions</span>
      <a href="{{ path('cotisation_index') }}" class="btn btn-sm btn-outline">Voir tout</a>
    </div>
    <div>
      {% for tx in dernieresTransactions %}
      <div style="display:flex; align-items:center; gap:12px; padding:12px 20px; border-bottom:1px solid #f1f5f9;">
        <img src="{{ tx.membre.photoUrl }}" alt="" class="avatar avatar-sm" onerror="this.src='/images/avatar-default.svg'">
        <div style="flex:1; min-width:0;">
          <div style="font-weight:600; font-size:13px; color:#1e293b; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ tx.membre.nomComplet }}</div>
          <div><span class="badge {{ tx.typeBadgeClass }}" style="font-size:10px;">{{ tx.typeLabel }}</span></div>
        </div>
        <div style="text-align:right; flex-shrink:0;">
          <div style="font-weight:800; color:#10b981; font-size:14px;">+{{ tx.montant|number_format(0, ',', ' ') }} F</div>
          <div class="hide-mobile" style="font-size:11px; color:#94a3b8;">{{ tx.datePaiement|date('d/m/Y') }}</div>
        </div>
      </div>
      {% else %}
      <div style="padding:40px; text-align:center; color:#94a3b8;">
        <i class="fas fa-inbox" style="font-size:32px; display:block; margin-bottom:8px; opacity:.3;"></i>
        Aucune transaction
      </div>
      {% endfor %}
    </div>
  </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
const CHART_COLORS = {
  blue:   '#1a56db', green: '#10b981', red: '#ef4444', yellow: '#f59e0b',
  purple: '#7c3aed', teal:  '#0d9488', pink: '#ec4899', orange: '#f97316',
};
const CHART_DEFAULTS = {
  font: { family: "'Inter', -apple-system, sans-serif" },
  plugins: { legend: { display: false }, tooltip: { bodyFont: { family: "'Inter', sans-serif" }, cornerRadius: 8, padding: 12 }},
};

Chart.defaults.font.family = "'Inter', -apple-system, sans-serif";

// ─── 1. ÉVOLUTION COTISATIONS (Bar + Line) ───────────────────────────────
const evolutionData = {{ stats.evolution|json_encode|raw }};
let chartEvolution;

function initChartEvolution(data) {
  const ctx = document.getElementById('chartEvolution').getContext('2d');
  if (chartEvolution) chartEvolution.destroy();
  chartEvolution = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: data.labels,
      datasets: [{
        label: 'Cotisations mensuelles (F CFA)',
        data: data.data,
        backgroundColor: data.data.map(v => v > 0 ? 'rgba(26,86,219,0.15)' : 'rgba(239,68,68,0.1)'),
        borderColor: data.data.map(v => v > 0 ? '#1a56db' : '#ef4444'),
        borderWidth: 2,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          cornerRadius: 8, padding: 12,
          callbacks: { label: ctx => `  ${new Intl.NumberFormat('fr-CI').format(ctx.raw)} F CFA` }
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 12 } } },
        y: { grid: { color: '#f1f5f9' }, ticks: { callback: v => new Intl.NumberFormat('fr-CI').format(v) + ' F', font: { size: 11 } } }
      }
    }
  });
}
initChartEvolution(evolutionData);

async function chargerEvolution(annee) {
  const res = await fetch(`/api/stats/evolution/${annee}`);
  const data = await res.json();
  initChartEvolution(data);
}

// ─── 2. STATUTS MEMBRES (Doughnut) ──────────────────────────────────────
new Chart(document.getElementById('chartStatuts').getContext('2d'), {
  type: 'doughnut',
  data: {
    labels: ['Actifs', 'Inactifs', 'Anciens'],
    datasets: [{
      data: [{{ stats.membres.Actif }}, {{ stats.membres.Inactif }}, {{ stats.membres['Ancien Membre'] ?? 0 }}],
      backgroundColor: ['#10b981', '#ef4444', '#94a3b8'],
      borderWidth: 0,
      hoverOffset: 6,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false, cutout: '68%',
    plugins: {
      legend: { display: false },
      tooltip: { cornerRadius: 8, padding: 10,
        callbacks: { label: ctx => `  ${ctx.label}: ${ctx.raw}` }
      }
    }
  }
});

// ─── 3. VILLAGES (Bar horizontal) ───────────────────────────────────────
const villagesData = {{ stats.repartitionVillages|json_encode|raw }};
new Chart(document.getElementById('chartVillages').getContext('2d'), {
  type: 'bar',
  data: {
    labels: villagesData.map(v => v.village?.substring(0, 15) || 'N/A'),
    datasets: [{
      data: villagesData.map(v => parseInt(v.total)),
      backgroundColor: ['#1a56db','#10b981','#f59e0b','#7c3aed','#ef4444'].slice(0, villagesData.length),
      borderRadius: 6,
      borderSkipped: false,
    }]
  },
  options: {
    indexAxis: 'y', responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false }, tooltip: { cornerRadius: 8 }},
    scales: {
      x: { grid: { color: '#f1f5f9' }, ticks: { stepSize: 1, font: { size: 11 } } },
      y: { grid: { display: false }, ticks: { font: { size: 11 } } }
    }
  }
});

// ─── 4. GENRE (Doughnut) ────────────────────────────────────────────────
const genreData = {{ stats.repartitionGenre|json_encode|raw }};
new Chart(document.getElementById('chartGenre').getContext('2d'), {
  type: 'doughnut',
  data: {
    labels: genreData.map(g => g.genre),
    datasets: [{
      data: genreData.map(g => parseInt(g.total)),
      backgroundColor: ['#3b82f6','#ec4899'],
      borderWidth: 0,
      hoverOffset: 6,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false, cutout: '60%',
    plugins: {
      legend: { display: true, position: 'bottom', labels: { padding: 12, font: { size: 12 } }},
      tooltip: { cornerRadius: 8, callbacks: { label: ctx => `  ${ctx.label}: ${ctx.raw}` }}
    }
  }
});

// ─── 5. TYPES COTISATIONS (Pie) ──────────────────────────────────────────
const typesData = {{ stats.typesCotisations|json_encode|raw }};
const typeLabels = { mensuelle:'Mensuelle', exceptionnelle:'Exceptionnelle', sociale:'Sociale', adhesion:'Adhésion' };
new Chart(document.getElementById('chartTypes').getContext('2d'), {
  type: 'pie',
  data: {
    labels: typesData.map(t => typeLabels[t.type] || t.type),
    datasets: [{
      data: typesData.map(t => parseFloat(t.total)),
      backgroundColor: ['#1a56db','#10b981','#f59e0b','#7c3aed'],
      borderWidth: 2, borderColor: 'white',
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: true, position: 'bottom', labels: { padding: 10, font: { size: 11 }, boxWidth: 12 }},
      tooltip: { cornerRadius: 8, callbacks: { label: ctx => `  ${ctx.label}: ${new Intl.NumberFormat('fr-CI').format(ctx.raw)} F` }}
    }
  }
});
</script>
{% endblock %}
