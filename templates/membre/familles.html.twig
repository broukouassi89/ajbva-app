{% extends 'base.html.twig' %}
{% block title %}Grandes Familles{% endblock %}
{% block breadcrumb %}
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Familles</span>
{% endblock %}
{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Répertoire par Famille</h1>
        <p class="page-subtitle">Visualisation des membres regroupés par grande famille</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 24px;">
    {% for nomFamille, membres in familles %}
    <div class="card">
        <div class="card-header" style="background: #f8fafc;">
            <h3 class="card-title"><i class="fas fa-users"></i> {{ nomFamille }}</h3>
            <span class="badge badge-primary">{{ membres|length }}</span>
        </div>
        <div class="card-body" style="padding: 0;">
            <table style="width: 100%;">
                {% for m in membres %}
                <tr style="border-bottom: 1px solid #f1f5f9;">
                    <td style="padding: 10px 15px;">
                        <a href="{{ path('membre_show', {id: m.id}) }}" class="fw-600">{{ m.nomComplet }}</a>
                        <br><small class="text-muted">{{ m.identifiant }}</small>
                    </td>
                    <td style="padding: 10px 15px; text-align: right;">
                        <span class="badge {{ m.statutBadgeClass }}">{{ m.statut }}</span>
                    </td>
                </tr>
                {% endfor %}
            </table>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}
