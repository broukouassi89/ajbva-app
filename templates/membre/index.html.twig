{% extends 'base.html.twig' %}
{% block title %}Membres{% endblock %}
{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <a href="{{ path('membre_index') }}" class="breadcrumb-current">Membres</a>
{% endblock %}
{% block header_actions %}
  {% if is_granted('ROLE_BUREAU') %}
  <a href="{{ path('membre_export_excel') }}" class="header-btn"><i class="fas fa-file-excel"></i> Export CSV</a>
  <a href="{{ path('membre_new') }}" class="header-btn primary"><i class="fas fa-user-plus"></i> Nouveau membre</a>
  {% endif %}
{% endblock %}

{% block content %}

<div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 20px;">
  <div class="stat-card">
    <div class="stat-icon si-blue"><i class="fas fa-users"></i></div>
    <div><div class="stat-value">{{ stats.total }}</div><div class="stat-label">Total membres</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-green"><i class="fas fa-user-check"></i></div>
    <div><div class="stat-value">{{ stats.Actif }}</div><div class="stat-label">Actifs</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-red"><i class="fas fa-user-times"></i></div>
    <div><div class="stat-value">{{ stats.Inactif }}</div><div class="stat-label">Inactifs</div></div>
  </div>
</div>

{# Filtres #}
<div class="card mb-24">
  <div class="card-body" style="padding:16px 20px;">
    <form method="GET" action="{{ path('membre_index') }}" style="display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end;">
      <div style="flex:1; min-width:200px;">
        <label class="form-label" style="margin-bottom:4px;">Rechercher</label>
        <div style="position:relative;">
          <i class="fas fa-search" style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#94a3b8;"></i>
          <input type="text" name="search" value="{{ filters.search }}" class="form-control" style="padding-left:34px;" placeholder="Nom, prénom, identifiant...">
        </div>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Statut</label>
        <select name="statut" class="form-control form-select" style="min-width:130px;">
          <option value="">Tous</option>
          <option value="Actif" {{ filters.statut == 'Actif' ? 'selected' : '' }}>Actif</option>
          <option value="Inactif" {{ filters.statut == 'Inactif' ? 'selected' : '' }}>Inactif</option>
          <option value="Ancien Membre" {{ filters.statut == 'Ancien Membre' ? 'selected' : '' }}>Ancien Membre</option>
        </select>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Genre</label>
        <select name="genre" class="form-control form-select" style="min-width:120px;">
          <option value="">Tous</option>
          <option value="Masculin" {{ filters.genre == 'Masculin' ? 'selected' : '' }}>♂ Masculin</option>
          <option value="Féminin" {{ filters.genre == 'Féminin' ? 'selected' : '' }}>♀ Féminin</option>
        </select>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Village</label>
        <select name="village" class="form-control form-select" style="min-width:140px;">
          <option value="">Tous</option>
          {% for v in villages %}<option value="{{ v }}" {{ filters.village == v ? 'selected' : '' }}>{{ v }}</option>{% endfor %}
        </select>
      </div>
      <div>
        <label class="form-label" style="margin-bottom:4px;">Famille</label>
        <select name="famille" class="form-control form-select" style="min-width:155px;">
          <option value="">Toutes</option>
          {% for f in familles %}<option value="{{ f }}" {{ filters.famille == f ? 'selected' : '' }}>{{ f }}</option>{% endfor %}
        </select>
      </div>
      <div style="display:flex; gap:6px;">
        <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i></button>
        <a href="{{ path('membre_index') }}" class="btn btn-outline"><i class="fas fa-times"></i></a>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-list"></i> Liste des membres</span>
    <span class="text-muted" style="font-size:13px;">{{ membres.getTotalItemCount }} résultat(s)</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Membre</th>
          <th class="hide-mobile">Genre / Âge</th>
          <th class="hide-tablet">Contact</th>
          <th class="hide-tablet">Village / Famille</th>
          <th class="hide-mobile">Date adhésion</th>
          <th class="hide-tablet">Ancienneté</th>
          <th>Statut</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for membre in membres %}
        <tr>
          <td>
            <div style="display:flex; align-items:center; gap:12px;">
              <img src="{{ membre.photoUrl }}" class="avatar avatar-sm" onerror="this.src='/images/avatar-default.svg'">
              <div>
                <div style="font-weight:700; color:var(--dark);">{{ membre.nomComplet }}</div>
                <div style="font-size:11px; color:var(--gray); font-family:monospace;">{{ membre.identifiant }}</div>
              </div>
            </div>
          </td>
          <td class="hide-mobile">
            <div style="font-size:13px; font-weight:500;">{{ membre.genreIcon }} {{ membre.genre }}</div>
            <div style="font-size:11px; color:var(--gray);">{{ membre.age }} ans</div>
          </td>
          <td class="hide-tablet">
            <div style="font-size:13px; font-weight:500;"><i class="fas fa-phone" style="font-size:11px; color:var(--gray); margin-right:4px;"></i>{{ membre.telephone }}</div>
            <div style="font-size:11px; color:var(--gray);">{{ membre.email }}</div>
          </td>
          <td class="hide-tablet">
            <div style="font-size:13px; font-weight:500;">{{ membre.villageOrigine }}</div>
            <div style="font-size:11px; color:var(--gray);">{{ membre.grandeFamille }}</div>
          </td>
          <td class="hide-mobile">
            <div style="font-size:13px; font-weight:500;">{{ membre.dateAdhesion|date('d/m/Y') }}</div>
          </td>
          <td class="hide-tablet">
            <div class="badge badge-secondary">{{ membre.anciennete }}</div>
          </td>
          <td><span class="badge {{ membre.statutBadgeClass }}">{{ membre.statut }}</span></td>
          <td style="text-align:right;">
            <div style="display:flex; gap:4px; justify-content:flex-end;">
              <a href="{{ path('membre_show', {id: membre.id}) }}" class="btn btn-ghost btn-sm" title="Voir la fiche"><i class="fas fa-eye"></i></a>
              {% if is_granted('ROLE_BUREAU') %}
              <a href="{{ path('membre_edit', {id: membre.id}) }}" class="btn btn-ghost btn-sm" title="Modifier" style="color:#1a56db;"><i class="fas fa-edit"></i></a>
              <a href="{{ path('cotisation_new') }}?membre_id={{ membre.id }}" class="btn btn-ghost btn-sm" title="Cotisation" style="color:#10b981;"><i class="fas fa-plus-circle"></i></a>
              {% endif %}
            </div>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="8" style="text-align:center; padding:50px; color:#94a3b8;">
          <i class="fas fa-users" style="font-size:36px; display:block; margin-bottom:12px; opacity:.2;"></i>
          Aucun membre trouvé
        </td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# Pagination KNP #}
  {% if membres.pageCount > 1 %}
  <div class="pagination">
    {{ knp_pagination_render(membres) }}
  </div>
  {% endif %}
</div>
{% endblock %}
