{% extends 'base.html.twig' %}
{% block title %}{{ membre.nomComplet }} — Fiche{% endblock %}
{% block breadcrumb %}
  <span class="breadcrumb-sep">/</span>
  <a href="{{ path('membre_index') }}" style="color:#64748b;">Membres</a>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">{{ membre.nomComplet }}</span>
{% endblock %}
{% block header_actions %}
  {% if is_granted('ROLE_BUREAU') %}
  <a href="{{ path('membre_edit', {id: membre.id}) }}" class="header-btn"><i class="fas fa-edit"></i> Modifier</a>
  <a href="{{ path('cotisation_new') }}?membre_id={{ membre.id }}" class="header-btn primary"><i class="fas fa-plus-circle"></i> Cotisation</a>
  {% endif %}
{% endblock %}

{% block content %}

{# ─── Hero Fiche ─── #}
<div class="card mb-24" style="overflow:visible;">
  <div style="background:linear-gradient(135deg,#0f172a 0%,#1a56db 100%);padding:32px 32px 0;border-radius:14px 14px 0 0;position:relative;">
    <div style="position:absolute;top:0;right:0;width:220px;height:220px;background:rgba(255,255,255,.04);border-radius:50%;transform:translate(60px,-60px);"></div>
    <div style="position:absolute;bottom:0;left:0;width:160px;height:160px;background:rgba(255,255,255,.03);border-radius:50%;transform:translate(-40px,40px);"></div>
    <div style="display:flex;align-items:flex-end;gap:28px;position:relative;">
      <div style="position:relative;flex-shrink:0;">
        <img src="{{ membre.photoUrl }}" alt="{{ membre.nomComplet }}"
             style="width:110px;height:110px;border-radius:50%;object-fit:cover;border:4px solid white;box-shadow:0 8px 24px rgba(0,0,0,.3);"
             onerror="this.src='/images/avatar-default.svg'">
        <span style="position:absolute;bottom:6px;right:6px;width:22px;height:22px;background:{{ membre.statut == 'Actif' ? '#10b981' : '#ef4444' }};border-radius:50%;border:3px solid white;"></span>
      </div>
      <div style="flex:1;padding-bottom:24px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;flex-wrap:wrap;">
          <h1 style="color:white;font-size:24px;font-weight:800;">{{ membre.nomComplet }}</h1>
          <span style="background:rgba(255,255,255,.15);color:{{ membre.genreCssColor }};padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">
            {{ membre.genreIcon }} {{ membre.genre }}
          </span>
        </div>
        <div style="color:rgba(255,255,255,.5);font-size:13px;font-family:monospace;margin-bottom:10px;">{{ membre.identifiant }}</div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;">
          <div style="color:rgba(255,255,255,.75);font-size:13px;"><i class="fas fa-map-marker-alt" style="margin-right:5px;"></i>{{ membre.villageOrigine ?? 'Village N/A' }}</div>
          <div style="color:rgba(255,255,255,.75);font-size:13px;"><i class="fas fa-users" style="margin-right:5px;"></i>{{ membre.grandeFamille ?? 'Famille N/A' }}</div>
          <div style="color:rgba(255,255,255,.75);font-size:13px;"><i class="fas fa-calendar-alt" style="margin-right:5px;"></i>Membre depuis {{ membre.anciennete }}</div>
        </div>
      </div>
      <div style="padding-bottom:24px; display:flex; flex-direction:column; align-items:flex-end; gap:8px;">
        <span class="badge {{ membre.statutBadgeClass }}" style="padding:8px 18px;font-size:13px;">{{ membre.statut }}</span>
        
        {% if is_granted('ROLE_ADMIN') and membre.user and membre.user.mustChangePassword %}
          <form action="{{ path('membre_reset_password', {id: membre.id}) }}" method="POST" onsubmit="return confirm('Générer un nouveau mot de passe temporaire pour ce membre ?');">
            <button type="submit" class="btn btn-warning btn-sm" style="font-size:11px; padding:4px 10px;">
              <i class="fas fa-key"></i> Réinitialiser l'accès
            </button>
          </form>
        {% endif %}
      </div>
    </div>
  </div>

  {# Barre progression cotisations #}
  <div style="padding:18px 28px;border-bottom:1px solid #e2e8f0;background:#fafbfc;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
      <div style="font-size:13px;color:#64748b;font-weight:600;">Progression cotisations {{ annee }}</div>
      <div>
        {% set obj_annuel = get_setting('cotisation_annuelle', 18000) %}
        <span style="font-size:20px;font-weight:800;color:#1a56db;">{{ cotisationsAnnee|number_format(0,',',' ') }}</span>
        <span style="color:#94a3b8;"> / {{ obj_annuel|number_format(0,',',' ') }} F CFA</span>
        <span style="margin-left:10px;font-size:14px;font-weight:700;color:{{ pourcentage == 100 ? '#10b981' : '#f59e0b' }};">{{ pourcentage }}%</span>
      </div>
    </div>
    <div class="progress" style="height:10px;">
      <div class="progress-bar {{ pourcentage == 100 ? 'pb-green' : pourcentage >= 50 ? 'pb-blue' : 'pb-yellow' }}" style="width:{{ pourcentage }}%;"></div>
    </div>
    {% if pourcentage < 100 %}
    <div style="font-size:12px;color:#f59e0b;margin-top:6px;font-weight:600;">
      <i class="fas fa-exclamation-circle"></i> Reste {{ (obj_annuel - cotisationsAnnee)|number_format(0,',',' ') }} F CFA à payer
    </div>
    {% else %}
    <div style="font-size:12px;color:#10b981;margin-top:6px;font-weight:600;"><i class="fas fa-check-circle"></i> Objectif annuel atteint !</div>
    {% endif %}
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

  {# Infos personnelles #}
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-user-circle"></i> Informations personnelles</span>
      {% if is_granted('ROLE_BUREAU') %}
      <a href="{{ path('membre_edit', {id: membre.id}) }}" class="btn btn-ghost btn-sm"><i class="fas fa-edit"></i></a>
      {% endif %}
    </div>
    <div class="card-body" style="padding:0;">
      {% set infos = [
        ['id-badge','Identifiant', membre.identifiant, 'font-family:monospace;color:#1a56db;font-weight:700;'],
        ['venus-mars','Genre', membre.genreIcon ~ ' ' ~ membre.genre, ''],
        ['birthday-cake','Date de naissance', membre.dateNaissance|date('d/m/Y'), ''],
        ['calculator','Âge', membre.age ~ ' ans', 'font-weight:700;color:#1a56db;'],
        ['calendar-check',"Date d'adhésion", membre.dateAdhesion|date('d/m/Y'), ''],
        ['clock','Ancienneté', membre.anciennete, 'font-weight:600;color:#10b981;'],
        ['phone','Téléphone', membre.telephone, ''],
        ['envelope','Email', membre.email ?? 'Non renseigné', membre.email ? '' : 'color:#94a3b8;font-style:italic;'],
        ['map-marker-alt','Village', membre.villageOrigine ?? '—', ''],
        ['people-group','Grande famille', membre.grandeFamille ?? '—', ''],
      ] %}
      <table style="width:100%;">
        {% for row in infos %}
        <tr style="border-bottom:1px solid #f8fafc;">
          <td style="padding:11px 18px;color:#64748b;font-size:13px;font-weight:500;width:42%;white-space:nowrap;">
            <i class="fas fa-{{ row[0] }}" style="width:18px;text-align:center;margin-right:6px;"></i>{{ row[1] }}
          </td>
          <td style="padding:11px 18px;font-size:13.5px;{{ row[3] }}">{{ row[2] }}</td>
        </tr>
        {% endfor %}
      </table>

      {% if is_granted('ROLE_BUREAU') %}
      <div style="padding:16px 18px;border-top:1px solid #e2e8f0;">
        <div style="font-size:11px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;">Changer le statut</div>
        <form method="POST" action="{{ path('membre_statut', {id: membre.id}) }}" style="display:flex;gap:8px;flex-wrap:wrap;">
          <input type="hidden" name="_token" value="{{ csrf_token('statut_' ~ membre.id) }}">
          <button name="statut" value="Actif" class="btn btn-success btn-sm" {{ membre.statut == 'Actif' ? 'disabled' : '' }}><i class="fas fa-check"></i> Actif</button>
          <button name="statut" value="Inactif" class="btn btn-warning btn-sm" {{ membre.statut == 'Inactif' ? 'disabled' : '' }}><i class="fas fa-pause"></i> Inactif</button>
          <button name="statut" value="Ancien Membre" class="btn btn-outline btn-sm" {{ membre.statut == 'Ancien Membre' ? 'disabled' : '' }}><i class="fas fa-history"></i> Ancien</button>
        </form>
      </div>
      {% endif %}
    </div>
  </div>

  {# Graphique cotisations mensuelles du membre #}
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="fas fa-chart-bar"></i> Cotisations {{ annee }}</span></div>
    <div class="card-body">
      <div class="chart-container" style="height:220px;"><canvas id="chartMembre"></canvas></div>
      <div style="text-align:center;margin-top:12px;font-size:13px;color:#64748b;">
        Total payé : <strong style="color:#1a56db;">{{ cotisationsAnnee|number_format(0,',',' ') }} F CFA</strong>
        / Objectif : <strong>{{ get_setting('cotisation_annuelle', 18000)|number_format(0,',',' ') }} F CFA</strong>
      </div>
    </div>
  </div>
</div>

{# État des arriérés #}
{% if arrieres.total > 0 %}
<div class="card mb-24" style="border-left: 5px solid #ef4444;">
  <div class="card-header" style="background: #fef2f2;">
    <span class="card-title text-danger"><i class="fas fa-exclamation-triangle"></i> État des arriérés et dettes</span>
    <span class="badge badge-danger" style="font-size: 14px;">Total dû : {{ arrieres.total|number_format(0,',',' ') }} F CFA</span>
  </div>
  <div class="card-body">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
      <div style="padding: 15px; background: #fff; border: 1px solid #fee2e2; border-radius: 10px;">
        <div style="font-size: 12px; color: #991b1b; font-weight: 700; text-transform: uppercase;">Mensuels en retard</div>
        <div style="font-size: 24px; font-weight: 800; color: #ef4444; margin: 5px 0;">{{ arrieres.mensuel|number_format(0,',',' ') }} F</div>
        <div style="font-size: 12px; color: #b91c1c;">Correspond à {{ arrieres.nbMoisRetard }} mois d'impayés</div>
      </div>
      
      {% for type, montant in arrieres.autres %}
      <div style="padding: 15px; background: #fff; border: 1px solid #fee2e2; border-radius: 10px;">
        <div style="font-size: 12px; color: #991b1b; font-weight: 700; text-transform: uppercase;">{{ type }}</div>
        <div style="font-size: 24px; font-weight: 800; color: #ef4444; margin: 5px 0;">{{ montant|number_format(0,',',' ') }} F</div>
        <div style="font-size: 12px; color: #b91c1c;">Action requise</div>
      </div>
      {% endfor %}
    </div>
    
    {% if is_granted('ROLE_BUREAU') %}
    <div style="margin-top: 20px; padding-top: 15px; border-top: 1px dashed #fca5a5;">
      <p style="font-size: 13px; color: #64748b; margin-bottom: 10px;">
        <i class="fas fa-info-circle"></i> Le paiement d'une cotisation mensuelle réduira automatiquement l'arriéré mensuel calculé depuis la date d'adhésion ({{ membre.dateAdhesion|date('d/m/Y') }}).
      </p>
      <a href="{{ path('cotisation_new') }}?membre_id={{ membre.id }}" class="btn btn-danger btn-sm">
        <i class="fas fa-hand-holding-dollar"></i> Régulariser la situation
      </a>
    </div>
    {% endif %}
  </div>
</div>
{% endif %}

{# Historique cotisations #}
<div class="card mb-20">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-history"></i> Historique des paiements</span>
    {% if is_granted('ROLE_BUREAU') %}
    <a href="{{ path('cotisation_new') }}?membre_id={{ membre.id }}" class="btn btn-sm btn-primary"><i class="fas fa-plus"></i> Enregistrer</a>
    {% endif %}
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>N° Reçu</th><th>Type</th><th>Montant</th><th>Date</th><th>Mois</th><th>Statut</th><th>Note</th></tr>
      </thead>
      <tbody>
        {% for c in membre.cotisations %}
        <tr>
          <td class="font-mono" style="font-size:12px;color:#64748b;">{{ c.recuNumero ?? '—' }}</td>
          <td><span class="badge {{ c.typeBadgeClass }}">{{ c.typeLabel }}</span></td>
          <td style="font-weight:700;color:#10b981;">+{{ c.montant|number_format(0,',',' ') }} F</td>
          <td style="color:#64748b;">{{ c.datePaiement|date('d/m/Y') }}</td>
          <td style="color:#94a3b8;font-size:12px;">{{ c.moisConcerne ?? '—' }}</td>
          <td><span class="badge {{ c.statutBadgeClass }}">{{ c.statutLabel }}</span></td>
          <td style="color:#94a3b8;font-size:12px;">{{ c.note ?? '—' }}</td>
        </tr>
        {% else %}
        <tr><td colspan="7" style="text-align:center;padding:30px;color:#94a3b8;">Aucun paiement enregistré</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{# Cas sociaux #}
{% if membre.casSociaux|length > 0 %}
<div class="card">
  <div class="card-header"><span class="card-title"><i class="fas fa-heart-pulse"></i> Affaires sociales</span></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Type</th><th>Date</th><th>Assistance</th><th>Statut</th><th>Paiement</th></tr></thead>
      <tbody>
        {% for cas in membre.casSociaux %}
        <tr>
          <td><span style="margin-right:6px;">{{ cas.typeIcon }}</span>{{ cas.type }}</td>
          <td>{{ cas.dateEvenement|date('d/m/Y') }}</td>
          <td style="font-weight:700;color:#1a56db;">{{ cas.montantAssistanceFormate }}</td>
          <td><span class="badge {{ cas.statutBadgeClass }}">{{ cas.statutAssistance }}</span></td>
          <td style="color:#64748b;font-size:12px;">{{ cas.datePaiementAssistance ? cas.datePaiementAssistance|date('d/m/Y') : '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

{% endblock %}

{% block javascripts %}
<script>
// Graphique cotisations mensuelles du membre
const cotisationsData = [
  {% for c in membre.cotisations %}
    {% if c.type == 'mensuelle' and c.datePaiement|date('Y') == annee %}
    { mois: {{ c.datePaiement|date('n') }}, montant: {{ c.montant }} },
    {% endif %}
  {% endfor %}
];

const moisLabels = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
const data = Array(12).fill(0);
cotisationsData.forEach(c => { data[c.mois - 1] += c.montant; });

new Chart(document.getElementById('chartMembre').getContext('2d'), {
  type: 'bar',
  data: {
    labels: moisLabels,
    datasets: [{
      label: 'Cotisations (F CFA)',
      data: data,
      backgroundColor: data.map(v => v >= 1500 ? 'rgba(16,185,129,0.2)' : v > 0 ? 'rgba(245,158,11,0.2)' : 'rgba(239,68,68,0.08)'),
      borderColor: data.map(v => v >= 1500 ? '#10b981' : v > 0 ? '#f59e0b' : '#e2e8f0'),
      borderWidth: 2, borderRadius: 6, borderSkipped: false,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false }, tooltip: { cornerRadius: 8, callbacks: { label: c => `  ${new Intl.NumberFormat('fr-CI').format(c.raw)} F CFA` } }},
    scales: {
      x: { grid: { display: false }, ticks: { font: { size: 11 } }},
      y: { grid: { color: '#f8fafc' }, max: 3000, ticks: { callback: v => v.toLocaleString() + ' F', font: { size: 10 } }},
    }
  }
});
</script>
{% endblock %}
