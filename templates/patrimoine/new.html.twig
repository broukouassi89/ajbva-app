{% extends 'base.html.twig' %}
{% block title %}Nouveau bien patrimonial{% endblock %}

{% block content %}
<div class="card" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header"><h3 class="card-title">Enregistrer un bien</h3></div>
    <div class="card-body">
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nom) }}
            </div>
            
            <div class="form-group">
                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    {{ form_label(form.valeurAchat, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.valeurAchat, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.valeurAchat) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.dateAcquisition, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateAcquisition, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateAcquisition) }}
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    {{ form_label(form.etat, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.etat, {'attr': {'class': 'form-control form-select'}}) }}
                    {{ form_errors(form.etat) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.projet, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.projet, {'attr': {'class': 'form-control form-select'}}) }}
                    {{ form_errors(form.projet) }}
                </div>
            </div>

            <div class="mt-16">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-save"></i> Enregistrer le bien
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
