{% extends 'base.html.twig' %}
{% block title %}Patrimoine{% endblock %}
{% block breadcrumb %}<span class="breadcrumb-sep">/</span><span class="breadcrumb-current">Patrimoine</span>{% endblock %}
{% block header_actions %}
  {% if is_granted('ROLE_BUREAU') %}
  <a href="{{ path('patrimoine_new') }}" class="header-btn primary"><i class="fas fa-plus"></i> Nouveau bien</a>
  {% endif %}
{% endblock %}

{% block content %}
<div class="page-header">
  <div>
    <div class="page-title">Patrimoine associatif</div>
    <div class="page-subtitle">Inventaire des biens appartenant à l'AJBVA</div>
  </div>
</div>

{# KPI total #}
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px;">
  <div class="stat-card">
    <div class="stat-icon si-blue"><i class="fas fa-building"></i></div>
    <div><div class="stat-value">{{ patrimoines|length }}</div><div class="stat-label">Biens répertoriés</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-green"><i class="fas fa-euro-sign"></i></div>
    <div>
      <div class="stat-value" style="font-size:18px;">{{ valeurTotale|number_format(0,',',' ') }}</div>
      <div class="stat-label">Valeur totale (F CFA)</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon si-teal"><i class="fas fa-check-circle"></i></div>
    <div>
      <div class="stat-value">{{ patrimoines|filter(p => p.etat == 'Bon état')|length }}</div>
      <div class="stat-label">En bon état</div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><span class="card-title"><i class="fas fa-list"></i> Inventaire</span></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Désignation</th><th>Valeur d'achat</th><th>Date acquisition</th><th>Projet lié</th><th>État</th></tr></thead>
      <tbody>
        {% for p in patrimoines %}
        <tr>
          <td>
            <div style="font-weight:700;font-size:13.5px;color:#1e293b;">{{ p.nom }}</div>
            {% if p.description %}<div style="font-size:12px;color:#94a3b8;">{{ p.description|slice(0,60) }}</div>{% endif %}
          </td>
          <td style="font-weight:700;color:#1a56db;font-size:14px;">{{ p.valeurAchat|number_format(0,',',' ') }} F CFA</td>
          <td style="color:#64748b;">{{ p.dateAcquisition|date('d/m/Y') }}</td>
          <td style="font-size:13px;color:#64748b;">{{ p.projet ? p.projet.nom : '—' }}</td>
          <td><span class="badge {{ p.etatBadgeClass }}">{{ p.etat }}</span></td>
        </tr>
        {% else %}
        <tr><td colspan="5" style="text-align:center;padding:50px;color:#94a3b8;">
          <i class="fas fa-box-open" style="font-size:36px;display:block;margin-bottom:12px;opacity:.2;"></i>Aucun bien enregistré
        </td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
